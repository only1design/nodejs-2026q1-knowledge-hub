# In-container configuration: used by `npm run docker:up` when the app runs inside Docker.

# Docker PostgreSQL setup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Postgres connection string used by Prisma (composed from POSTGRES_* above)
DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledge_hub

# Port the app listens on
PORT=4000

# JWT configuration — CHANGE for any deployment beyond local dev
JWT_SECRET=your_access_token_secret
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Logging
# Supported levels (cascading, from least to most verbose): fatal, error, warn, log, debug, verbose
LOG_LEVEL=debug
# Max log file size in KB before rotation
LOG_MAX_FILE_SIZE=1024

# AI module
# REQUIRED for AI/RAG features. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3-flash-preview
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300

# RAG module — see doc/rag.md for details
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
RAG_VECTOR_DB_URL=http://vectordb:6333
RAG_VECTOR_COLLECTION=knowledge_hub_articles
EMBEDDING_DIMENSION=768
# Chunks per Gemini embed call
EMBEDDING_BATCH_SIZE=100
# Chunk length in characters
RAG_CHUNK_SIZE=800
# Overlap between consecutive chunks, in characters
RAG_CHUNK_OVERLAP=200
RAG_CONVERSATION_MAX_MESSAGES=20
RAG_RETRIEVAL_SEMANTIC_SCORE_THRESHOLD=0.7
RAG_RETRIEVAL_HYBRID_SCORE_THRESHOLD=0.1
RAG_RETRIEVAL_TOP_K=10
RAG_RERANK_ENABLED=true
RAG_RERANK_CANDIDATE_MULTIPLIER=3
RAG_RERANK_MMR_LAMBDA=0.5