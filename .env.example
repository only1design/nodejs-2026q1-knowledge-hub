PORT=4000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledge_hub
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/knowledge_hub

JWT_SECRET=your_access_token_secret
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Supported levels (cascading, from least to most verbose): fatal, error, warn, log, debug, verbose
LOG_LEVEL=debug
LOG_MAX_FILE_SIZE=1024

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3-flash-preview
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300

GEMINI_EMBEDDING_MODEL=gemini-embedding-2
RAG_VECTOR_DB_URL=http://vectordb:6333
RAG_VECTOR_COLLECTION=knowledge_hub_articles
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=100
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_CONVERSATION_MAX_MESSAGES=20
RAG_RETRIEVAL_SEMANTIC_SCORE_THRESHOLD=0.7
RAG_RETRIEVAL_HYBRID_SCORE_THRESHOLD=0.1
RAG_RETRIEVAL_TOP_K=10
RAG_RERANK_ENABLED=true
RAG_RERANK_CANDIDATE_MULTIPLIER=3
RAG_RERANK_MMR_LAMBDA=0.5
