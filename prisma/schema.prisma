generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id        String @id @unique
  login     String
  password  String
  role      Role
  createdAt Int
  updatedAt Int

  articles Article[]
  comments Comment[]
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id         String        @id @unique
  title      String
  content    String
  status     ArticleStatus
  authorId   String?
  categoryId String?
  createdAt  Int
  updatedAt  Int

  author   User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments Comment[]
  tags     Tag[]
}

model Category {
  id          String @id @unique
  name        String
  description String

  articles Article[]
}

model Comment {
  id        String  @id @unique
  content   String
  authorId  String?
  articleId String
  createdAt Int

  author  User?   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Tag {
  id   String @id @unique
  name String @unique

  articles Article[]
}
